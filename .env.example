# ========================================
# Variables de Entorno - Club Socios Frontend
# ========================================

# DESARROLLO LOCAL
# ----------------------------------------
# En desarrollo local, NO se necesitan variables de entorno
# El proxy de Vite (vite.config.js) redirige automáticamente:
#   /api -> http://localhost:5055/api
#   /uploads -> http://localhost:5055/uploads

# PRODUCCIÓN (Railway)
# ----------------------------------------
# En Railway, configura esta variable de entorno en el dashboard:

# BACKEND_URL: URL completa del servicio backend en Railway
# Ejemplo: https://club-socios-backend-production.up.railway.app
BACKEND_URL=https://tu-backend.up.railway.app

# DOCKER LOCAL
# ----------------------------------------
# Si ejecutas con docker-compose o docker local:
# BACKEND_URL=http://backend:8080
