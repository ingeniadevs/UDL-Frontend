# ========================================
# Variables de Entorno - Club Socios Frontend
# ========================================

# DESARROLLO LOCAL
# ----------------------------------------
# En desarrollo local, puedes usar el proxy de Vite o configurar directamente

# Opción 1: Sin variable (usa proxy de Vite)
# El proxy en vite.config.js redirige /api -> http://localhost:5055

# Opción 2: Con variable (llamada directa al backend)
# VITE_API_URL=http://localhost:5055/api

# PRODUCCIÓN (Railway)
# ----------------------------------------
# IMPORTANTE: Configurar en Railway Dashboard como Build Variable
# Esta variable se usa durante el BUILD de la aplicación

# VITE_API_URL: URL completa del API del backend
# Ejemplo: https://club-socios-backend-production.up.railway.app/api
VITE_API_URL=https://tu-backend.up.railway.app/api

# DOCKER LOCAL
# ----------------------------------------
# Pasar como ARG durante el build:
# docker build --build-arg VITE_API_URL=http://backend:8080/api -t frontend .
# VITE_API_URL=http://backend:8080/api
